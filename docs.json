{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "One Perfect Slice",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Product",
            "pages": [
              "product/slices",
              "product/scorecards",
              "product/posts",
              "product/crm-integration",
              "product/api-keys"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api/openapi.yaml"
      },
      {
        "tab": "MCP",
        "groups": [
          {
            "group": "MCP Server",
            "pages": [
              "mcp/overview",
              "mcp/claude-code",
              "mcp/claude-desktop"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Reference",
          "href": "/api-reference",
          "icon": "terminal"
        },
        {
          "anchor": "MCP",
          "href": "/mcp/overview",
          "icon": "robot"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@oneperfectslice.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.oneperfectslice.ai"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/oneperfectslice"
    }
  },
  "api": {
    "baseUrl": "https://app.oneperfectslice.ai",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    }
  }
}
