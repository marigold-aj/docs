{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "One Perfect Slice",
  "appearance": {
    "default": "system"
  },
  "colors": {
    "primary": "#773624",
    "light": "#F08C80",
    "dark": "#261B15"
  },
  "font": {
    "headings": {
      "family": "Yantramanav",
      "weight": 700,
      "url": "https://fonts.googleapis.com/css2?family=Yantramanav:wght@400;500;600;700&display=swap"
    },
    "body": {
      "family": "Yantramanav",
      "weight": 400,
      "url": "https://fonts.googleapis.com/css2?family=Yantramanav:wght@400;500;600;700&display=swap"
    }
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Product",
            "pages": [
              "product/slices",
              "product/scorecards",
              "product/posts"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/hubspot"
            ]
          }
        ]
      },
      {
        "tab": "MCP",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "mcp/overview"
            ]
          },
          {
            "group": "Setup",
            "pages": [
              "mcp/claude-code",
              "mcp/claude-desktop"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "API Reference",
            "pages": [
              "api/authentication"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "api/openapi.yaml"
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/product/crm-integration",
      "destination": "/integrations/hubspot"
    },
    {
      "source": "/product/api-keys",
      "destination": "/api/authentication"
    }
  ],
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@oneperfectslice.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.oneperfectslice.ai"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/oneperfectslice"
    }
  },
  "api": {
    "baseUrl": "https://app.oneperfectslice.ai",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    }
  }
}
