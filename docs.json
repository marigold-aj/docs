{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "styling": {
    "css": ["/style.css"]
  },
  "name": "One Perfect Slice",
  "appearance": {
    "default": "system"
  },
  "colors": {
    "primary": "#773624",
    "light": "#F08C80",
    "dark": "#261B15"
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#1a1614"
    }
  },
  "font": {
    "headings": {
      "family": "Yantramanav",
      "weight": 700,
      "url": "https://fonts.googleapis.com/css2?family=Yantramanav:wght@400;500;600;700&display=swap"
    },
    "body": {
      "family": "Yantramanav",
      "weight": 400,
      "url": "https://fonts.googleapis.com/css2?family=Yantramanav:wght@400;500;600;700&display=swap"
    }
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "integrations/index"
            ]
          },
          {
            "group": "Product",
            "pages": [
              "product/slices",
              "product/summaries",
              "product/scorecards",
              "product/call-types"
            ]
          },
          {
            "group": "Accounts",
            "pages": [
              "accounts/overview",
              "accounts/roles-and-permissions"
            ]
          }
        ]
      },
      {
        "tab": "MCP",
        "groups": [
          {
            "group": "MCP",
            "pages": [
              "mcp/overview",
              "mcp/tools"
            ]
          },
          {
            "group": "Setup",
            "pages": [
              "mcp/claude-code",
              "mcp/claude-desktop",
              "mcp/codex"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "API",
            "pages": [
              "api/introduction",
              "api/authentication",
              "api/endpoints",
              "api/rate-limiting",
              "api/pagination",
              "api/errors"
            ]
          },
          {
            "group": "Endpoint Details",
            "openapi": "api/openapi.yaml"
          },
          {
            "group": "Reference",
            "pages": [
              "api/data-models"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/product/crm-integration",
      "destination": "/integrations/hubspot"
    },
    {
      "source": "/product/api-keys",
      "destination": "/api/authentication"
    },
    {
      "source": "/product/posts",
      "destination": "/product/summaries"
    },
    {
      "source": "/product/call-classification",
      "destination": "/product/call-types"
    }
  ],
  "logo": {
    "light": "https://cdn.prod.website-files.com/6798f568c3016c7a6d112142/679d400304f43a0293bc36b1_oneperfectslice-logo.svg",
    "dark": "https://cdn.prod.website-files.com/6798f568c3016c7a6d112142/679d400304f43a0293bc36b1_oneperfectslice-logo.svg"
  },
  "integrations": {
    "ga4": {
      "measurementId": "G-FWXSKEJF5P"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/oneperfectslice"
    }
  },
  "api": {
    "baseUrl": "https://app.oneperfectslice.ai",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    },
    "examples": {
      "languages": ["python", "javascript", "curl"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    },
    "playground": {
      "display": "interactive",
      "proxy": true
    }
  }
}
