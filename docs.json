{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "One Perfect Slice",
  "appearance": "system",
  "colors": {
    "primary": "#773624",
    "light": "#F08C80",
    "dark": "#261B15",
    "background": {
      "light": "#FFFFFF",
      "dark": "#0f1117"
    }
  },
  "font": {
    "headings": {
      "family": "Yantramanav",
      "weight": 700,
      "url": "https://fonts.googleapis.com/css2?family=Yantramanav:wght@400;500;600;700&display=swap"
    },
    "body": {
      "family": "Yantramanav",
      "weight": 400,
      "url": "https://fonts.googleapis.com/css2?family=Yantramanav:wght@400;500;600;700&display=swap"
    }
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          }
        ]
      },
      {
        "tab": "Product",
        "groups": [
          {
            "group": "Product",
            "pages": [
              "product/slices",
              "product/scorecards",
              "product/posts",
              "product/crm-integration",
              "product/api-keys"
            ]
          }
        ]
      },
      {
        "tab": "Developers",
        "groups": [
          {
            "group": "API Reference",
            "pages": [
              "quickstart"
            ],
            "openapi": "api/openapi.yaml"
          },
          {
            "group": "MCP Server",
            "pages": [
              "mcp/overview",
              "mcp/claude-code",
              "mcp/claude-desktop"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Developers",
          "href": "/quickstart",
          "icon": "terminal"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@oneperfectslice.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.oneperfectslice.ai"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/oneperfectslice"
    }
  },
  "api": {
    "baseUrl": "https://app.oneperfectslice.ai",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    }
  }
}
